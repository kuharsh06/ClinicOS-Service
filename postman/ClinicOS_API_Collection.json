              "raw": "{\n  \"name\": \"Dr. Kumar's Clinic\",\n  \"address\": \"123 Main Street\",\n  \"city\": \"Patna\",\n  \"state\": \"Bihar\",\n  \"pin\": \"800001\",\n  \"logo\": null,\n  \"brandColor\": \"#2563EB\",\n  \"smsLanguage\": \"hi\",\n  \"clinicalDataVisibility\": \"all_members\",\n  \"workingHours\": {\n    \"monday\": { \"shifts\": [{ \"open\": \"09:00\", \"close\": \"13:00\" }, { \"open\": \"17:00\", \"close\": \"20:00\" }] },\n    \"tuesday\": { \"shifts\": [{ \"open\": \"09:00\", \"close\": \"13:00\" }, { \"open\": \"17:00\", \"close\": \"20:00\" }] },\n    \"wednesday\": { \"shifts\": [{ \"open\": \"09:00\", \"close\": \"13:00\" }, { \"open\": \"17:00\", \"close\": \"20:00\" }] },\n    \"thursday\": { \"shifts\": [{ \"open\": \"09:00\", \"close\": \"13:00\" }, { \"open\": \"17:00\", \"close\": \"20:00\" }] },\n    \"friday\": { \"shifts\": [{ \"open\": \"09:00\", \"close\": \"13:00\" }, { \"open\": \"17:00\", \"close\": \"20:00\" }] },\n    \"saturday\": { \"shifts\": [{ \"open\": \"09:00\", \"close\": \"13:00\" }] },\n    \"sunday\": { \"shifts\": [] }\n  },\n  \"creator\": {\n    \"name\": \"Dr. Rajesh Kumar\"\n  }\n}"
            },
            "url": {
